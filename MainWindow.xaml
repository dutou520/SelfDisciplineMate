<Window x:Class="SelfDisciplineMate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SelfDisciplineMate.ViewModels"
        xmlns:converters="clr-namespace:SelfDisciplineMate.Converters"
        mc:Ignorable="d"
        Title="自律桌面伴侣"
        Height="700"
        Width="450"
        MinHeight="600"
        MinWidth="400"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:SecondsToTimeConverter x:Key="SecondsToTime"/>
        <converters:PomodoroStateToColorConverter x:Key="StateToColor"/>
        <converters:PomodoroStateToTextConverter x:Key="StateToText"/>
        <converters:WeightToStarsConverter x:Key="WeightToStars"/>
        <converters:PermissionUnlockedConverter x:Key="PermissionUnlockedConverter"/>
        <converters:CompletedBackgroundConverter x:Key="CompletedBackgroundConverter"/>
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>
    </Window.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">

                <!-- 标题栏 -->
                <TextBlock Text="🍅 自律桌面伴侣"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- 番茄钟面板 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- 状态显示 -->
                        <TextBlock Text="{Binding CurrentPomodoroState, Converter={StaticResource StateToText}}"
                                   FontSize="16"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <!-- 倒计时显示 -->
                        <Border Background="{Binding CurrentPomodoroState, Converter={StaticResource StateToColor}}"
                                CornerRadius="100"
                                Width="180"
                                Height="180"
                                Margin="0,8">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding RemainingSeconds, Converter={StaticResource SecondsToTime}}"
                                           FontSize="48"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding CompletedPomodoros, StringFormat='番茄 x{0}'}"
                                           FontSize="14"
                                           Foreground="White"
                                           Opacity="0.8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- 控制按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Button Content="开始"
                                    Command="{Binding StartCommand}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="80"
                                    Margin="8,0"/>
                            <Button Content="暂停"
                                    Command="{Binding PauseCommand}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="80"
                                    Margin="8,0"/>
                            <Button Content="重置"
                                    Command="{Binding ResetCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="60"
                                    Margin="8,0"/>
                            <Button Content="跳过"
                                    Command="{Binding SkipCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="60"
                                    Margin="8,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 任务面板 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="✅ 今日任务" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TodayTasks.Count, StringFormat='共 {0} 项'}"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </Grid>

                        <!-- 添加新任务 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="12,8"
                                     FontSize="14"
                                     BorderBrush="#E0E0E0"/>
                            <Button Grid.Column="1"
                                    Content="添加"
                                    Command="{Binding AddTaskCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="8,0,0,0"/>
                        </Grid>

                        <!-- 任务列表 -->
                        <ItemsControl ItemsSource="{Binding TodayTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4"
                                            Padding="12"
                                            CornerRadius="6"
                                            Background="{Binding IsCompleted, Converter={StaticResource CompletedBackgroundConverter}}"
                                            AllowDrop="True"
                                            PreviewMouseLeftButtonDown="Task_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="Task_PreviewMouseMove"
                                            Drop="Task_Drop">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox IsChecked="{Binding IsCompleted}"
                                                      Command="{Binding DataContext.ToggleTaskCompletionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"
                                                      VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       FontSize="14"
                                                       Margin="8,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource CompletedTextBrush}"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="False">
                                                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- 权重星级 -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0">
                                                <Button Content="−"
                                                        Command="{Binding DataContext.DecreaseWeightCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        FontSize="12"/>
                                                <TextBlock Text="{Binding Weight, Converter={StaticResource WeightToStars}}"
                                                           FontSize="12"
                                                           Foreground="#FFD700"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0"/>
                                                <Button Content="+"
                                                        Command="{Binding DataContext.IncreaseWeightCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        FontSize="12"/>
                                            </StackPanel>

                                            <Button Grid.Column="3"
                                                    Content="🗑"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="删除任务"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="暂无任务，添加一个新任务开始吧！"
                                   Visibility="{Binding TodayTasks.Count, Converter={StaticResource ZeroToVisibility}}"
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16"/>
                    </StackPanel>
                </Border>

                <!-- 进度面板 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📊 今日进度" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TodayCompletionRate, StringFormat='{}{0:F0}%'}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </Grid>

                        <ProgressBar Value="{Binding TodayCompletionRate}"
                                     Maximum="100"
                                     Height="8"
                                     Margin="0,12,0,8"
                                     Foreground="{StaticResource PrimaryBrush}"
                                     Background="#E0E0E0"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="昨日:"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,0,4,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding YesterdayCompletionRate, StringFormat='{}{0:F0}%'}"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding CompletedPomodoros, StringFormat='🍅 {0} 个'}"
                                       FontSize="12"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </Grid>

                        <TextBlock Text="{Binding PromptMessage}"
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 娱乐权限面板 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="🎮 娱乐权限" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <ItemsControl>
                            <ItemsControl.Items>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{Binding CurrentPermission, Converter={StaticResource PermissionUnlockedConverter}, ConverterParameter=Overwatch}" FontSize="14"/>
                                    <TextBlock Text="守望先锋级 (90%+)" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{Binding CurrentPermission, Converter={StaticResource PermissionUnlockedConverter}, ConverterParameter=Minecraft}" FontSize="14"/>
                                    <TextBlock Text="Minecraft级 (80%+)" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{Binding CurrentPermission, Converter={StaticResource PermissionUnlockedConverter}, ConverterParameter=Steam}" FontSize="14"/>
                                    <TextBlock Text="Steam级 (70%+)" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{Binding CurrentPermission, Converter={StaticResource PermissionUnlockedConverter}, ConverterParameter=Godot}" FontSize="14"/>
                                    <TextBlock Text="Godot级 (60%+)" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{Binding CurrentPermission, Converter={StaticResource PermissionUnlockedConverter}, ConverterParameter=UE_Engine}" FontSize="14"/>
                                    <TextBlock Text="UE引擎级 (40%+)" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{Binding CurrentPermission, Converter={StaticResource PermissionUnlockedConverter}, ConverterParameter=Blender}" FontSize="14"/>
                                    <TextBlock Text="Blender级 (20%+)" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </ItemsControl.Items>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 底部操作 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,16">
                    <Button Content="📅 月历"
                            Click="OpenCalendar_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="⚙️ 设置"
                            Click="OpenSettings_Click"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
