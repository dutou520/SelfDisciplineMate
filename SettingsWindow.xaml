<Window x:Class="SelfDisciplineMate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:SelfDisciplineMate.Converters"
        mc:Ignorable="d"
        Title="设置"
        Height="600"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Text="⚙️ 设置"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,24"/>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 番茄钟设置 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="番茄钟设置" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="专注时长 (分钟)" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding FocusDuration}"
                                     Padding="8,4"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="短休息 (分钟)" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShortBreakDuration}"
                                     Padding="8,4"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="长休息 (分钟)" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding LongBreakDuration}"
                                     Padding="8,4"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="长休息间隔 (番茄数)" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding PomodorosUntilLongBreak}"
                                     Padding="8,4"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 通用设置 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="通用设置" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <CheckBox Content="开机自启动"
                                  IsChecked="{Binding StartWithWindows}"
                                  Margin="0,8"/>

                        <CheckBox Content="关闭窗口时最小化到托盘"
                                  IsChecked="{Binding MinimizeToTray}"
                                  Margin="0,8"/>

                        <CheckBox Content="播放提示音"
                                  IsChecked="{Binding PlaySound}"
                                  Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- 应用拦截设置 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="应用拦截配置" FontSize="16" FontWeight="SemiBold"/>
                            <Button Grid.Column="1"
                                    Content="添加应用"
                                    Command="{Binding AddAppMappingCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="12,4"/>
                        </Grid>

                        <!-- 警告信息 -->
                        <Border Background="#FFF3E0"
                                CornerRadius="4"
                                Padding="12"
                                Margin="0,0,0,12"
                                Visibility="{Binding RequiresAdmin, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="⚠️ 修改拦截配置需要管理员权限。点击「应用策略」后请以管理员身份运行程序。"
                                       TextWrapping="Wrap"
                                       Foreground="#E65100"/>
                        </Border>

                        <!-- 应用列表 -->
                        <ItemsControl ItemsSource="{Binding AppMappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding AppName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding ExePath}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding DataContext.LevelOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      DisplayMemberPath="Value"
                                                      SelectedValuePath="Key"
                                                      SelectedValue="{Binding RequiredLevel}"
                                                      Margin="8,0"
                                                      Width="120" />

                                            <Button Grid.Column="2"
                                                    Content="🗑"
                                                    Command="{Binding DataContext.RemoveAppMappingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="移除"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="尚未配置任何应用拦截"
                                   Visibility="{Binding AppMappings.Count, Converter={StaticResource ZeroToVisibility}}"
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12"/>

                        <!-- 策略按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Button Content="应用拦截策略"
                                    Command="{Binding ApplyBlockPolicyCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="8,0"/>
                            <Button Content="清除拦截策略"
                                    Command="{Binding ClearBlockPolicyCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 状态信息 -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{StaticResource SuccessBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8"/>

            </StackPanel>
        </ScrollViewer>

        <!-- 保存按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="保存设置"
                    Command="{Binding SaveSettingsCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="120"/>
            <Button Content="关闭"
                    Click="Close_Click"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="80"
                    Margin="12,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
