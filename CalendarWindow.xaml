<Window x:Class="SelfDisciplineMate.CalendarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:SelfDisciplineMate.Converters"
        mc:Ignorable="d"
        Title="月度统计"
        Height="500"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <converters:IntToVisibilityConverter x:Key="IntToVisibility"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 月份导航 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="◀"
                    Command="{Binding PreviousMonthCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="40"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding MonthYearDisplay}"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="2"
                    Content="▶"
                    Command="{Binding NextMonthCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="40"/>
        </Grid>

        <!-- 星期标题 -->
        <UniformGrid Grid.Row="1" Columns="7" Margin="0,0,0,8">
            <TextBlock Text="日" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#F44336"/>
            <TextBlock Text="一" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="二" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="三" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="四" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="五" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="六" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#F44336"/>
        </UniformGrid>

        <!-- 日历网格 -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Days}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="2"
                            CornerRadius="4"
                            Height="50"
                            BorderThickness="1"
                            BorderBrush="#E0E0E0"
                            Background="{Binding CompletionColor}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                        <Setter Property="BorderThickness" Value="3"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="#9C27B0"/>
                                        <Setter Property="BorderThickness" Value="3"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Grid>
                            <TextBlock Text="{Binding Day}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,4,0,0"
                                       Foreground="White"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,4">
                                <TextBlock Text="{Binding CompletionRate, StringFormat='{}{0:F0}%'}"
                                           FontSize="10"
                                           Foreground="White"/>
                                <TextBlock Text=" · "
                                           FontSize="10"
                                           Foreground="White"
                                           Visibility="{Binding PomodoroCount, Converter={StaticResource IntToVisibility}}"/>
                                <TextBlock Text="{Binding PomodoroCount, StringFormat='🍅{0}'}"
                                           FontSize="10"
                                           Foreground="White"
                                           Visibility="{Binding PomodoroCount, Converter={StaticResource IntToVisibility}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 图例 -->
        <Border Grid.Row="3" Margin="0,16,0,0" Padding="12" Background="#F5F5F5" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="图例说明" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <UniformGrid Columns="3" Rows="2">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Border Width="16" Height="16" Background="#4CAF50" CornerRadius="2"/>
                        <TextBlock Text=" 100%" FontSize="11" Margin="4,0,8,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Border Width="16" Height="16" Background="#8BC34A" CornerRadius="2"/>
                        <TextBlock Text=" 80-99%" FontSize="11" Margin="4,0,8,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Border Width="16" Height="16" Background="#FFC107" CornerRadius="2"/>
                        <TextBlock Text=" 60-79%" FontSize="11" Margin="4,0,8,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Border Width="16" Height="16" Background="#FF9800" CornerRadius="2"/>
                        <TextBlock Text=" 40-59%" FontSize="11" Margin="4,0,8,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Border Width="16" Height="16" Background="#FF5722" CornerRadius="2"/>
                        <TextBlock Text=" 20-39%" FontSize="11" Margin="4,0,8,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Border Width="16" Height="16" Background="#E0E0E0" CornerRadius="2"/>
                        <TextBlock Text=" 0-19%" FontSize="11" Margin="4,0,8,0"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
